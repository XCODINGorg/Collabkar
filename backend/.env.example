##############################################
# Express Backend
##############################################

# Server
PORT=4001
CORS_ORIGIN=http://localhost:3000

# Auth (rotate for production)
AUTH_JWT_SECRET=change-me
AUTH_JWT_EXPIRES_IN=7d
AUTH_PASSWORD_PEPPER=change-me
AUTH_ALLOW_DEV_ADMIN_LOGIN=false

# Data stores
# Current backend uses MongoDB for influencer endpoints and auth users.
# For a free cloud setup, paste your MongoDB Atlas M0 connection string here.
MONGODB_URI=mongodb://localhost:27017/collabkar

# Planned: Postgres for scraped data, datasets, and deals.
# DATABASE_URL=postgresql://collabkar:collabkar@localhost:5432/collabkar

# Internal AI service (FastAPI). This is NOT an external AI provider.
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_MS=10000

# Public URL of your frontend (used for email verification / OAuth redirect)
APP_BASE_URL=http://localhost:3000

# Email verification delivery (no paid email provider required)
# - If AUTH_EMAIL_WEBHOOK_URL is set, backend POSTs verification payload there.
# - Otherwise the verification link is logged to the backend console.
AUTH_EMAIL_WEBHOOK_URL=
AUTH_EMAIL_VERIFY_TOKEN_TTL_MIN=60

# OAuth (Continue with Google / Facebook / Apple)
# These require creating apps with each provider and setting redirect URIs.
OAUTH_STATE_SECRET=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4001/api/auth/oauth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:4001/api/auth/oauth/facebook/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PEM=
APPLE_REDIRECT_URI=http://localhost:4001/api/auth/oauth/apple/callback

# Scraper controls (Instaloader)
SCRAPER_BATCH_SIZE=50
SCRAPER_MAX_REQUESTS_PER_MIN=60
SCRAPER_LAST_SCRAPED_WINDOW_HOURS=24
SCRAPER_USERNAMES_SEED_FILE=./data/seed_usernames.txt

# Local model storage (joblib artifacts, vectorizers, etc.)
AI_MODELS_DIR=./data/models

# Waitlist (optional)
# WAITLIST_FILE_PATH=C:\path\to\waitlist-emails.csv
# WAITLIST_WEBHOOK_URL=https://your-pc-bridge-url.example.com/waitlist
